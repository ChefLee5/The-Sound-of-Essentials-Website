    {
      "week": 5,
      "theme": "Body, Mind & Balance",
      "primary_land": 5,
      "days": [
        {"week": 5, "day": 1, "day_label": "Monday", "day_title": "Mind-Body Morning", "primary_land": 5, "primary_land_color": "#c4785a", "primary_char_img": "NERISSA.jpg", "primary_char_names": "Nerissa & Octavia", "blocks": {"A": {"title": "Mental Health & Emotions", "time": 3, "img": "land5_mental-health-emotions.jpg", "img_alt": "Children expressing emotions safely in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "MEN-tul-HELTH | ANG-ZY-uh-tee | JOY | STRESS | KAM", "instructions": "Write 6 emotions from the picture. Write when you feel each one. Draw 3 healthy things you can do when feeling upset or anxious.", "tip": "Octavia says: All feelings are valid. What matters is what you DO with them!"},
        "B": {"title": "Basic Math Facts Sprint", "time": 3, "img": "land2_basic-math-operations.jpg", "img_alt": "Math fact flashcards in Numeria sprint challenge", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "FAKT | SPEED | PRAK-tis | MAS-ter | TIYMD", "instructions": "Time yourself: write all multiples of 3 up to 30. Then all multiples of 4 up to 40. Then all multiples of 7 up to 70. Beat your time!", "tip": "Kwame says: Math facts are your mental tools. Sharper tools = faster building!"},
        "C": {"title": "Inside the Body Systems", "time": 3, "img": "land5_inside-the-body.jpg", "img_alt": "Human body internal organs in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "DY-jest | SIR-kyoo-layt | BREETH | SENS | NAYRV", "instructions": "Write the 3 body systems from the picture. For each: Name of system + its job + one organ that belongs to it. Draw one system!", "tip": "Nerissa says: Your body has 11 major systems all working together every second!"},
        "D": {"title": "Vitalis Yoga Moves", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "Yoga poses for children in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "YO-guh | POSE | BAL-ens | BREETH | STRENG-th | FLEX", "instructions": "Try 3 yoga poses: Mountain pose (stand tall, 10 breaths), Warrior I (lunge forward, arms up, 5 breaths), Child's pose (fold forward, 10 breaths).", "tip": "Octavia says: Yoga is strength, flexibility AND calm all in one. It's a full body upgrade!"},
        "E": {"title": "Aquaria: Freshwater Life", "time": 2, "img": "land4_freshwater-life.jpg", "img_alt": "Fish, frogs and plants in freshwater habitat", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "FRESH-wah-ter | FROG | FISH | AL-gee | DRAGONFLY | POND", "instructions": "Write 4 freshwater animals. Write: Does it live IN the water, ON the water, or NEAR the water? Draw a labeled freshwater food chain!", "tip": "Ronan says: Freshwater is rare \u2014 only 3% of Earth's water is fresh. Every drop counts!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "How does your body feel right now? Rate each: energy (1-5), mood (1-5), focus (1-5). What does your body need today?"}}},
        {"week": 5, "day": 2, "day_label": "Tuesday", "day_title": "Kitchen Science", "primary_land": 5, "primary_land_color": "#c4785a", "primary_char_img": "OCTAVIA.jpg", "primary_char_names": "Octavia & Nerissa", "blocks": {"A": {"title": "Meal Time Vocabulary", "time": 3, "img": "land5_meal-time.jpg", "img_alt": "Family eating a healthy meal in Vitalis dining room", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "MEAL | BREK-fust | LUN-ch | DIN-er | SNAKS | TEB-ul", "instructions": "Write 8 meal-related words from the picture. Plan a healthy breakfast using words from the picture. Write ingredients and one reason it's nutritious.", "tip": "Nerissa says: Breakfast fuels your morning brain. It's the most important input!"},
        "B": {"title": "Fractions in the Kitchen", "time": 3, "img": "land2_cooking-measurements.jpg", "img_alt": "Baking with fractions in Numeria kitchen", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "FRAK-shun | HAF | QWAR-ter | THIRD | MEZ-er", "instructions": "A recipe needs 3/4 cup of flour. You want to make double. How much flour do you need? Half the recipe? Show ALL your work with fraction drawings!", "tip": "Kwame says: Doubling or halving recipes is the most delicious fraction practice!"},
        "C": {"title": "Kitchen Science Lab", "time": 3, "img": "land3_the-barnyard.jpg", "img_alt": "Farm animals and barns in Terrasol countryside", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "BARN | KAO | PIG | HEN | EGG | MIL-k | WOOL", "instructions": "Write 5 farm animals and one food they give us (cow\u2192milk, hen\u2192egg). Draw a barnyard scene with labels. Which animal gives us the most products?", "tip": "Vesta says: Farms are the original food factories. Farmers are heroes!"},
        "D": {"title": "Vitalis Doctor's Visit", "time": 2, "img": "land5_the-doctors-office.jpg", "img_alt": "A friendly doctor's office in Vitalis medical center", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "DOKT-er | NURS | CHECK-up | VIT-uls | STETH-oh-skope", "instructions": "Write 5 doctor's office words. When did you last have a check-up? Write 3 questions you would ask your doctor if you could see one today.", "tip": "Octavia says: Asking doctors questions is how you take charge of your health!"},
        "E": {"title": "Sophia: Forms & Documents", "time": 2, "img": "land6_forms-documents.jpg", "img_alt": "Official forms and documents in Sophia city hall", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "FORM | DOK-yoo-ment | SIGN | DATE | ID | FILL-in", "instructions": "Fill in this mini form: Full Name, Date, City, Favorite Subject, Signature. Why do we need forms? Write 2 reasons documents are important.", "tip": "Athena says: Knowing how to fill out forms is a real-world life skill. Practice today!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "What is one healthy habit you want to start this week? Write it as a goal: I will ___ every day for ___ days."}}},
        {"week": 5, "day": 3, "day_label": "Wednesday", "day_title": "Energy & Rest", "primary_land": 5, "primary_land_color": "#c4785a", "primary_char_img": "NERISSA.jpg", "primary_char_names": "Nerissa & Octavia", "blocks": {"A": {"title": "The Pharmacy Vocabulary", "time": 3, "img": "land5_the-pharmacy.jpg", "img_alt": "Medicine bottles and pharmacy in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "FAR-muh-see | MED-ih-sin | DOSE | PRE-skrip-shun | AL-er-jee", "instructions": "Write 5 pharmacy words. Why is it important to follow medicine instructions carefully? Write 2 rules for taking medicine safely.", "tip": "Nerissa says: ALWAYS ask a trusted adult before taking any medicine. Always!"},
        "B": {"title": "Numeria Calendar & Planning", "time": 3, "img": "land2_calendar-math.jpg", "img_alt": "Monthly calendar with events marked", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "SKED-yool | PLAN | EVENT | DEAD-line | RE-mind-er", "instructions": "Mark YOUR current month's calendar: circle today, draw a star on your birthday month, add 3 summer plans with dates. How many school days until September?", "tip": "Kwame says: Planning ahead puts YOU in charge of your time. Own your calendar!"},
        "C": {"title": "Energy & Forces", "time": 3, "img": "land7_energy-forces.jpg", "img_alt": "Solar, wind, and water energy in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "EN-er-jee | FORCE | PUSH | PULL | SO-ler | WIND", "instructions": "Write 3 types of energy from the picture. For each: What is the source? How do we use it? Is it renewable? Draw YOUR favorite energy source!", "tip": "Elias says: The sun powers all life on Earth \u2014 directly or indirectly. It's the original power source!"},
        "D": {"title": "Vitalis Sleep Experiment", "time": 2, "img": "land5_sleep-rest.jpg", "img_alt": "Sleep tracking chart in Vitalis wellness center", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "TIRED | ENERGIZED | HOURS | TRACK | AVER-ij", "instructions": "Find out: How many hours did you sleep the last 3 nights? Calculate the average. Are you getting the 9-11 hours kids need? Make a plan!", "tip": "Octavia says: Consistent sleep beats occasional long sleeps. Routine is key!"},
        "E": {"title": "Aquaria: Road Signs Safety", "time": 2, "img": "land4_road-signs-safety.jpg", "img_alt": "Traffic signs and pedestrian safety in Aquaria streets", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "STOP | YELD | SPEED | KROSign | PEED-ES-tree-an", "instructions": "Draw and label 5 road signs from memory. Write what each one means. Which sign is most important for pedestrians (people walking)?", "tip": "Selene says: Understanding road signs keeps everyone safe. Signs speak a universal language!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "Rate your energy today (1-5). What gave you energy? What drained you? Write one change that could help you feel more energized tomorrow."}}},
        {"week": 5, "day": 4, "day_label": "Thursday", "day_title": "Strength & Strategy", "primary_land": 5, "primary_land_color": "#c4785a", "primary_char_img": "OCTAVIA.jpg", "primary_char_names": "Octavia & Nerissa", "blocks": {"A": {"title": "The Home Expanded", "time": 3, "img": "land1_the-home.jpg", "img_alt": "Expanded home vocabulary in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "PORCH | AK-atik | SEELER | YARD | FENCE | GAY-raj", "instructions": "Add 5 new home words to your vocabulary: attic, basement, porch, yard, garage. Write a sentence for each. Draw your dream home!", "tip": "Amara says: Your home vocabulary grows as your world grows!"},
        "B": {"title": "Money Management", "time": 3, "img": "land6_money-management-bills.jpg", "img_alt": "Bills and money management worksheets in Sophia", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "BIL | RENT | EL-ek-trik | FOOD | SAV-ings | NEEDS | WANTS", "instructions": "Sort these into Needs or Wants: food, game console, electricity, shoes, streaming service, medication, new toy. Total needs vs. wants. Which should come first?", "tip": "Athena says: Understanding needs vs. wants is the foundation of all financial wisdom!"},
        "C": {"title": "Silas & Vesta's Cottage", "time": 3, "img": "land3_silas-vestas-cottage-outside.jpg", "img_alt": "The outside of Silas and Vesta's cottage in Terrasol", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "KOT-ij | GAR-den | NECH-er | QUYET | HERBS | STREAM", "instructions": "Study the cottage carefully. Write 5 things you CAN see and 3 things you IMAGINE are inside. Why would you love or dislike living there?", "tip": "Silas says: Our cottage is small, but it has everything we need. Simplicity is power!"},
        "D": {"title": "Vitalis Sports Drill", "time": 2, "img": "land5_sports-fitness.jpg", "img_alt": "Sports drills and training in Vitalis arena", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "DRIL | TRAYN | PRAK-tis | KOOR-dih-nay-shun | AGIL-ih-tee", "instructions": "Agility drill: Lay out 5 spots on the floor (socks work!). Touch each with your right hand as fast as possible, then left hand. Time both rounds!", "tip": "Nerissa says: Agility is quick, controlled movement. It's useful in sports AND in life!"},
        "E": {"title": "Sophia: Job Interview Skills", "time": 2, "img": "land6_job-interview-skills.jpg", "img_alt": "A job interview scene in Sophia workplace", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "IN-ter-view | PO-liyt | KON-fi-dent | PRAK-tis | SKILL", "instructions": "Practice answering: 'What is your greatest strength?' and 'What do you want to improve?' Write both answers in full sentences. Then say them aloud!", "tip": "Felix says: Confidence is a skill, not a gift. Practice it daily!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "FELIX.jpg", "char_names": "Felix & Athena"},
        "F": {"reflection_prompt": "What is one thing your body can do that you're proud of? Write it and say it out loud. Your body is amazing!"}}},
        {"week": 5, "day": 5, "day_label": "Friday", "day_title": "Week 5 Balance Champion!", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "Elias & Ezra", "blocks": {"A": {"title": "School Events Recap", "time": 3, "img": "land1_school-events-activities.jpg", "img_alt": "Fun school events in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "FELD-TRI-p | FAIR | PLAY | SEL-eh-BRAY-shun | per-FOR-mans", "instructions": "Write about your best school memory from last year. Use: who, what, where, when, why. Write 4-6 sentences with descriptive details!", "tip": "Amara says: Your memories are your stories. Write them before you forget!"},
        "B": {"title": "Math Review Sprint", "time": 3, "img": "land2_basic-math-operations.jpg", "img_alt": "Mixed math practice problems in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "MIX | re-VIEW | PRAK-tis | ROUN | ES-tim-ayt", "instructions": "Solve: 23+45+17=?, 100-38=?, 8\u00d76=?, 42\u00f76=? Round 347 to nearest ten, hundred. Estimate 49+51 before calculating. Check each answer!", "tip": "Kwame says: Mixed practice is the best practice. It shows you what you truly know!"},
        "C": {"title": "Sustainability Check", "time": 3, "img": "land7_environment-sustainability.jpg", "img_alt": "Sustainable living practices in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "sus-TAYN-uh-bul | RE-nyoo-uh-bul | KAR-bon | EKO | GREEEN", "instructions": "Write 5 sustainable actions from the picture. Circle 3 you can do THIS WEEK. Make a 'Green Pledge' and write it formally: 'I, ___, promise to ___'", "tip": "Ezra says: Sustainable choices protect the future for everyone, including you!"},
        "D": {"title": "Vitalis Kitchen", "time": 2, "img": "land5_the-kitchen.jpg", "img_alt": "A well-organized kitchen in Vitalis home", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "KITCH-en | COOK | CHOP | MIX | SAIF | CLEAN", "instructions": "Write 5 kitchen safety rules. Ask an adult to teach you one simple cooking task today (stirring, peeling, washing). Write what you learned!", "tip": "Octavia says: Kitchen skills = independence skills. Learn one new kitchen task this summer!"},
        "E": {"title": "Celestia Week 5 Review", "time": 2, "img": "land7_the-scientific-method.jpg", "img_alt": "Scientific discovery in Celestia library", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "GROW | LEAR-n | STRENG-th | CHA-lenj | NEXT", "instructions": "Create a body-mind report card for this week. Grade yourself A-D on: Sleep, Nutrition, Exercise, Mindfulness, Learning. Set goals for Week 6!", "tip": "Elias says: Self-assessment is the highest form of learning. Be honest AND kind with yourself!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "Elias & Ezra"},
        "F": {"reflection_prompt": "5 weeks complete! You are a Summer Stretch Champion! Write: My biggest growth this summer has been ___ and next week I plan to ___"}}
        }
      ]
    },
    {
      "week": 6,
      "theme": "Inventions & Discoveries",
      "primary_land": 7,
      "days": [
        {"week": 6, "day": 1, "day_label": "Monday", "day_title": "Inventors & Innovations", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "Elias & Ezra", "blocks": {"A": {"title": "Inventions & Discoveries", "time": 3, "img": "land7_inventions-discoveries.jpg", "img_alt": "Famous inventions on display in Celestia museum", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "IN-ven-shun | DIS-KUV-er-ee | CREATE | IN-ven-tor | PA-tent", "instructions": "Write 4 inventions from the picture. For each: Who invented it? When? How did it change the world? Which is most important to you?", "tip": "Elias says: Every invention started with someone asking 'What if it worked differently?'"},
        "B": {"title": "Numeria Problem Solving", "time": 3, "img": "land2_problem-solving-logic.jpg", "img_alt": "Inventors using math to solve problems in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "SOL-vuh | CREE-ayt | TEST | FAIL | TRY-uh-gen", "instructions": "Invent a math word problem about your life. Include: a main character (you!), a problem, numbers to work with, and a final answer. Solve it!", "tip": "Kwame says: Inventors fail many times before succeeding. Failure is data, not defeat!"},
        "C": {"title": "Energy in Motion", "time": 3, "img": "land7_energy-forces.jpg", "img_alt": "Wind turbines, solar panels and water power", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "SO-ler | WIND | HY-dro | EL-ek-trik | RE-nyoo-uh-bul", "instructions": "Design your own energy invention! Draw it and explain: What energy source does it use? What problem does it solve? Who would use it?", "tip": "Vesta says: The world needs more energy inventors right now. Maybe that's you!"},
        "D": {"title": "Vitalis Bicycle & Walking", "time": 2, "img": "land4_bicycle-walking.jpg", "img_alt": "Healthy transportation by bike in Aquaria streets", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "BY-sikl | PED-ul | BAL-ens | HEL-met | SAFE", "instructions": "Go for a walk or bike ride (with a helmet!) for at least 10 minutes. When you return: write 5 things you observed outside. No screens \u2014 just eyes!", "tip": "Nerissa says: Walking or biking instead of driving is eco-friendly AND healthy. Double win!"},
        "E": {"title": "Aquaria: Public Transport", "time": 2, "img": "land4_public-transportation.jpg", "img_alt": "Buses, trains and subways in Aquaria city", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "BUS | TRAIN | SUB-way | SCHED-yool | FARE | ROUTE", "instructions": "Think about public transportation in your city. Write: 2 types available, a route you know, and 2 benefits of using public transport vs. a car.", "tip": "Ronan says: One full bus takes 40 cars off the road. Public transport protects the planet!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "What would YOU invent to make the world better? Draw it and write a 3-sentence pitch explaining your invention."}}},
        {"week": 6, "day": 2, "day_label": "Tuesday", "day_title": "Historical Timekeeping", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "EZRA.jpg", "primary_char_names": "Ezra & Elias", "blocks": {"A": {"title": "Ages & Life Stages", "time": 3, "img": "land7_ages-life-stages.jpg", "img_alt": "Human life stages from baby to elder in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "BAY-bee | CHILD | TEEN | A-DULT | ELD-er | LIFE-SAIKL", "instructions": "Draw a timeline of YOUR life so far. Mark: birth, first word, first step, starting school, today. Add 3 future milestones you're excited about!", "tip": "Ezra says: Your life is a story still being written. Every year is a new chapter!"},
        "B": {"title": "Numeria Time Concepts", "time": 3, "img": "land2_time-clocks.jpg", "img_alt": "Digital and analog clocks in multiple time zones", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "SEKON | MIN-it | HOUR | DAY | WEEK | MONTH | YEAR", "instructions": "Convert: 2 hours = __ minutes = __ seconds. 3 days = __ hours. 2 weeks = __ days. 1 year = __ days. How many seconds have you been alive?", "tip": "Kwame says: Time is the most precious resource because you can never get it back!"},
        "C": {"title": "Historical Timekeeping", "time": 3, "img": "land7_historical-timekeeping.jpg", "img_alt": "Sundials, hourglasses, and ancient clocks in Celestia museum", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "SUN-DY-ul | OUR-GLAS | PEN-dyu-lum | MECH-an-ik | DIJ-ih-tul", "instructions": "List 4 time-telling devices from history (oldest to newest). How did each work? Draw your favorite and write 2 sentences about why it's clever!", "tip": "Elias says: Before clocks, people read time in the sky. The stars are history's first clock!"},
        "D": {"title": "Vitalis Mindful Walk", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "A peaceful nature walk in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "MIND-ful | WOK | NO-tis | BREETH | PRES-ent | SENS-ez", "instructions": "Take a 5-minute mindful walk inside or outside. Notice: 5 things you see, 4 you hear, 3 you can touch, 2 you smell, 1 you taste. Write them all!", "tip": "Octavia says: Mindful walking is meditation in motion. It calms and energizes at the same time!"},
        "E": {"title": "Sophia: Voting & Elections", "time": 2, "img": "land6_voting-elections.jpg", "img_alt": "Voting booths and ballot boxes in Sophia democracy hall", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "VOT | e-LEK-shun | BAL-ot | DEM-oh-kra-see | CHOICE | VOICE", "instructions": "Run a classroom/family vote on something fun (best pizza topping, best movie genre). Create a ballot, count votes, announce the winner! Write the result.", "tip": "Athena says: Every vote matters. Democracy only works when everyone participates!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "What is one thing about history that amazes you? Write 2 sentences. What would you time-travel back to see?"}}},
        {"week": 6, "day": 3, "day_label": "Wednesday", "day_title": "Rhythm & Rhyme", "primary_land": 1, "primary_land_color": "#d4a843", "primary_char_img": "AMARA.jpg", "primary_char_names": "Amara & Kwame", "blocks": {"A": {"title": "Music & Rhythm", "time": 3, "img": "land7_time-in-music-rhythm.jpg", "img_alt": "Musical notation and rhythm patterns in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "RITH-um | BEET | ME-ter | PULSE | MEL-oh-dee | HAR-mo-nee", "instructions": "Clap this rhythm: CLAP-clap-clap CLAP-clap-clap (louder clap = strong beat). Write your own 4-beat rhythm pattern using BIG and small letters!", "tip": "Amara says: Language has rhythm too. Read this page aloud and feel the beat of words!"},
        "B": {"title": "Numeria Patterns Advanced", "time": 3, "img": "land2_patterns-sequences.jpg", "img_alt": "Advanced number patterns in Numeria sequence lab", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "SE-KWENS | RULE | GROW | SHRINK | FIB-on-a-chee", "instructions": "Continue these sequences: 2,4,8,16,_,_ | 100,90,81,73,_,_ | 1,1,2,3,5,8,_,_ (That last one is Fibonacci!). What's the RULE for each?", "tip": "Kwame says: The Fibonacci sequence appears in sunflowers, shells, and galaxies. Math is everywhere!"},
        "C": {"title": "Water Cycle Science", "time": 3, "img": "land7_the-water-cycle-weather-systems.jpg", "img_alt": "The full water cycle shown in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "EV-ap-oh-RAY-shun | CON-den-SAY-shun | PRE-sip-ih-TAY-shun | run-OFF", "instructions": "Draw the complete water cycle. Label all 4 steps: evaporation, condensation, precipitation, runoff. Add the sun and arrows showing direction!", "tip": "Silas says: The water you drink today may have been dinosaur rain. Water is ancient and endless!"},
        "D": {"title": "Vitalis Healthy Meal Plan", "time": 2, "img": "land5_nutrition-food-groups.jpg", "img_alt": "Balanced meal planning in Vitalis nutrition center", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "PLAN | BAL-anst | Nutrients | SERV-ing | VAR-ee-eh-tee", "instructions": "Plan one day of healthy eating: breakfast, snack, lunch, snack, dinner. Include at least 3 food groups in every meal. Calculate fruit/veg servings!", "tip": "Nerissa says: Meal planning is self-care in action. Plan ahead, eat well!"},
        "E": {"title": "Aquaria: Mail & Postal", "time": 2, "img": "land4_mail-postal-services.jpg", "img_alt": "Post boxes, stamps and delivery in Aquaria town", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "MALE | STAMP | PAK-ij | DE-liv-er | AD-ress | POST-of-is", "instructions": "Address a pretend letter to yourself (include: name, street, city, state, ZIP). Write a 3-sentence message inside. What would you tell past-you?", "tip": "Selene says: Writing letters is a kindness technology that never goes out of date!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "Write a 4-line poem about summer. It doesn't have to rhyme, but try! Share it with someone who loves you."}}},
        {"week": 6, "day": 4, "day_label": "Thursday", "day_title": "Hotels, Hosting & Hospitality", "primary_land": 4, "primary_land_color": "#2563EB", "primary_char_img": "RONAN.jpg", "primary_char_names": "Ronan & Selene", "blocks": {"A": {"title": "Manners Expanded", "time": 3, "img": "land1_manners-politeness.jpg", "img_alt": "Polite gestures and hospitality in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "HOS-pih-tal-ih-tee | GRATE-ful | WEL-kum | GUEST | SHARE", "instructions": "Write 6 actions that show hospitality (welcoming someone warmly). Roleplay: You have a guest from another country. Write what you'd say and do!", "tip": "Amara says: Hospitality is kindness with action. Make someone feel at home!"},
        "B": {"title": "Travel Budget Planning", "time": 3, "img": "land4_hotels-lodging.jpg", "img_alt": "Hotel lobby and travel expenses in Aquaria", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "HO-tel | LODGE | BUD-jet | BOOK | NITE | COST | PLAN", "instructions": "Plan a 3-day trip for 2 people: Hotel ($80/night), 3 meals/day ($15/meal), 1 activity ($30). What's the total trip cost? How much to save per week for 6 weeks?", "tip": "Kwame says: Travel budgeting is real-life math with real rewards!"},
        "C": {"title": "The Solar System", "time": 3, "img": "land7_the-solar-system.jpg", "img_alt": "Planets orbiting the sun in Celestia observatory", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "SOL-er-SIS-tem | PLAN-et | OR-bit | SUN | MOON | GRAV-ih-tee", "instructions": "Order the planets from the Sun: Mercury, Venus, Earth, Mars, Jupiter, Saturn, Uranus, Neptune. Write one amazing fact about your favorite planet!", "tip": "Elias says: If the Sun were a basketball, Earth would be the size of a pea. Scale is mind-bending!"},
        "D": {"title": "Vitalis Morning Routine", "time": 2, "img": "land5_healthy-habits-hygiene.jpg", "img_alt": "A complete healthy morning routine in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "ROOTING | KONSIST-ent | FIR-st | THEN | FINY-lee | HABBIT", "instructions": "Write your IDEAL morning routine step by step (8+ steps). Time how long each step takes. What total time do you need from wake-up to ready?", "tip": "Octavia says: A morning routine removes decisions so your brain can focus on learning!"},
        "E": {"title": "Sophia: Travel Documents", "time": 2, "img": "land4_travel-documents.jpg", "img_alt": "Passports, visas and travel papers in Sophia embassy", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "PAS-port | VI-za | ID | BORD-er | SIT-ih-zen-ship | FLY", "instructions": "Write 4 travel document vocabulary words and their definitions. Why do countries require passports? Write 2 reasons. Do you have a passport?", "tip": "Selene says: A passport is a ticket to the whole world. It says: 'This person belongs somewhere!'", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "Write about a place you want to visit someday. Why that place? What would you learn there? Who would you bring?"}}},
        {"week": 6, "day": 5, "day_label": "Friday", "day_title": "Week 6 Discovery Day!", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "Elias & Ezra", "blocks": {"A": {"title": "Digital Time & Screens", "time": 3, "img": "land7_digital-time-screens.jpg", "img_alt": "Screen time balance and digital wellness in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "SKREEN | DIG-ih-tul | BAL-ans | TECH-nol-oh-jee | LIMI-t", "instructions": "Track your screen time today: how many minutes? Write 3 activities that are not screen-based that you enjoy. Create your personal screen time rules!", "tip": "Ezra says: Tech is a tool, not a boss. Be intentional about how you use it!"},
        "B": {"title": "Number Patterns Challenge", "time": 3, "img": "land2_patterns-sequences.jpg", "img_alt": "Advanced pattern challenge in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "PAT-ern | RULE | FIND | EX-tend | CREE-ayt", "instructions": "Create 3 original number patterns. Write the first 5 terms + the rule for each. Trade with a family member and solve each other's patterns!", "tip": "Kwame says: Creating patterns is harder than solving them. You're thinking like a mathematician!"},
        "C": {"title": "Time Concepts & History", "time": 3, "img": "land7_time-concepts-history.jpg", "img_alt": "A historical timeline in Celestia archive", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "PAST | PREzent | FU-cher | TIME-lyne | HIss-tree | ERR-uh", "instructions": "Create a timeline of YOUR lifetime. Include: born, walked, talked, started school, learned to read, today, and 3 future goals. Draw it as an actual line!", "tip": "Elias says: Your personal history matters. It shapes who you are and who you'll become!"},
        "D": {"title": "Vitalis Sports Free Choice", "time": 2, "img": "land5_sports-fitness.jpg", "img_alt": "Children choosing their favorite sport in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "CHOICE | FAVE | ENJOY | GOOD-AT | GOAL", "instructions": "Choose YOUR favorite physical activity and do it for 10 minutes! Anything counts: dancing, jumping, walking, yoga. Write what you did and how you feel!", "tip": "Nerissa says: Exercise you LOVE is the best exercise. Find your joyful movement!"},
        "E": {"title": "Celestia Week 6 Review", "time": 2, "img": "land7_inventions-discoveries.jpg", "img_alt": "Inventions celebrated in Celestia innovation hall", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "INVENT | DIS-kover | CREATE | IMAG-in | EX-plore", "instructions": "Write your top 3 discoveries this week (facts, skills, or ideas). Draw your 'Invention of the Summer'\u2014something YOU could create to solve a real problem!", "tip": "Ezra says: The best inventors keep learning every day. Your next discovery is around the corner!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "Elias & Ezra"},
        "F": {"reflection_prompt": "6 weeks done! You are an INVENTOR of your own learning! Write: My greatest discovery this summer has been ___"}}
        }
      ]
    },
    {
      "week": 7,
      "theme": "Sound & Story",
      "primary_land": 1,
      "days": [
        {"week": 7, "day": 1, "day_label": "Monday", "day_title": "Storytelling Masters", "primary_land": 1, "primary_land_color": "#d4a843", "primary_char_img": "AMARA.jpg", "primary_char_names": "Amara & Kwame", "blocks": {"A": {"title": "Sight Words Review A", "time": 3, "img": "land1_greetings-introductions.jpg", "img_alt": "Essential sight words illustrated in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "THE | AND | IS | IT | WAS | ARE | HAVE | THIS | THAT", "instructions": "Write 10 sight words in a Word Wall grid. Use each in a sentence. Challenge: Write a 6-sentence story using only sight words!", "tip": "Amara says: Sight words are the glue of English. Master them and reading flows!"},
        "B": {"title": "Story Math Problems", "time": 3, "img": "land2_money-currency.jpg", "img_alt": "A Numeria marketplace math adventure", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "STOH-ree | PROB-lem | UNDR-stand | SOLVE | CHECK", "instructions": "Write and solve: Maya has 48 stickers. She gives 1/4 to her sister and buys 12 more. How many does she have? Show ALL steps. Write your own similar problem!", "tip": "Kwame says: Story problems connect math to real life. They're math in disguise!"},
        "C": {"title": "Animals in Terrasol", "time": 3, "img": "land3_pets-companions.jpg", "img_alt": "Animals as characters and companions in Terrasol", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "CHAR-ak-ter | AN-ih-mul | FABLE | LESON | MORAL | STORY", "instructions": "Pick an animal from the picture. Write a 5-sentence fable where the animal teaches a lesson. Include a 'Moral:' sentence at the end!", "tip": "Vesta says: Every animal has a story to tell. Be their author!"},
        "D": {"title": "Vitalis Story Moves", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "Children acting out a story with movement", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "AKT | MOVE | CHAR-ak-ter | FEEL | SHOW", "instructions": "Act out one scene from your favorite book or movie \u2014 with full body movement! No speaking, just movement. Can someone guess what scene it is?", "tip": "Nerissa says: Acting out stories is reading comprehension AND exercise in one!"},
        "E": {"title": "Aquaria: Airport & Travel", "time": 2, "img": "land4_the-airport-travel.jpg", "img_alt": "An airport scene in Aquaria international hub", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "AIR-port | GATE | BORD | BAG-ij | PAS-port | FLIYT", "instructions": "Write the steps to get on a plane in order (check-in, security, gate, boarding, takeoff). Have you flown before? Write 3 sentences about your experience!", "tip": "Ronan says: Airports are the crossroads of the world. Every flight carries a thousand stories!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "If your summer stretch was a story, what would the title be? Write 3 sentences describing the plot so far."}}},
        {"week": 7, "day": 2, "day_label": "Tuesday", "day_title": "Write Your World", "primary_land": 1, "primary_land_color": "#d4a843", "primary_char_img": "KWAME.jpg", "primary_char_names": "Kwame & Amara", "blocks": {"A": {"title": "Sight Words B", "time": 3, "img": "land1_communication-technology.jpg", "img_alt": "Words flying through communication channels", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "THEY | FROM | WITH | BEEN | WHAT | WHEN | THERE | WHERE | COULD", "instructions": "Write 10 Sight Words Group B. Use 5 of them in a letter to a friend describing your summer. Use at least 1 punctuation mark per sentence!", "tip": "Amara says: Writing letters is a gift. It shows you value someone enough to put words on paper!"},
        "B": {"title": "Numeria Geometry Review", "time": 3, "img": "land2_shapes-geometry.jpg", "img_alt": "Geometric shapes in an architecture puzzle", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "PER-im-eh-ter | AIR-ee-uh | VOL-yoom | ANG-gul | SIM-et-ree", "instructions": "Draw a rectangle 6cm x 4cm. Calculate: perimeter (all sides added) = ? Area (length x width) = ? Now draw 2 other shapes and do the same!", "tip": "Kwame says: Perimeter and area are what architects and builders use every day. Math builds worlds!"},
        "C": {"title": "The Water Cycle Story", "time": 3, "img": "land7_the-water-cycle-weather-systems.jpg", "img_alt": "Water cycle with weather system arrows", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "DROP | EVAPO-RAYT | CLOUD | RAIN | ROON-OFF | ABSORB", "instructions": "Write a story from the perspective of a water drop going through the complete water cycle. Use: first person ('I'), sensory details, and all 4 steps!", "tip": "Elias says: Science becomes meaningful when you put yourself inside the process. Become the water drop!"},
        "D": {"title": "Vitalis Writing Posture", "time": 2, "img": "land5_healthy-habits-hygiene.jpg", "img_alt": "Correct writing posture and ergonomics in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "POS-cher | SIT | STRAIGHT | WRIST | PEN-sil | GRIP", "instructions": "Check your posture right now: feet flat? Back straight? Paper tilted? Pencil grip correct? Make all 4 adjustments. Hold for 60 seconds. Feels better!", "tip": "Octavia says: Good posture while writing protects your neck, back, and focus. Sit strong!"},
        "E": {"title": "Sophia: Legal Terms Basics", "time": 2, "img": "land6_legal-court-terms.jpg", "img_alt": "Simple legal concepts shown in Sophia justice building", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "LAW | JUS-tis | FAYER | RULE | RITE | PRO-tek-shun", "instructions": "Write 3 legal words and what they mean in simple language. Why do communities need laws? Write 2 reasons. What would happen without any laws?", "tip": "Athena says: Laws protect everyone equally. Understanding them is a civic superpower!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "Write the beginning of a story. Give it a character, a setting, and a problem. Stop at the most exciting moment! Come back to it later!"}}},
        {"week": 7, "day": 3, "day_label": "Wednesday", "day_title": "Sound Science", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "Elias & Ezra", "blocks": {"A": {"title": "Sight Words C", "time": 3, "img": "land1_music-instruments.jpg", "img_alt": "Musical story words floating in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "THEIR | WOULD | SHOULD | THROUGH | THOUGH | THOUGHT | OUGHT", "instructions": "Write 10 Sight Words Group C \u2014 these are tricky! Practice each one 3 times. Write 5 sentences using at least 2 sight words each.", "tip": "Kwame says: Tricky words become easy words with enough practice. Repetition IS learning!"},
        "B": {"title": "Data Collection Project", "time": 3, "img": "land2_data-statistics.jpg", "img_alt": "Graphs and data display boards in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "SUR-vay | KWEST-yun | COL-ekt | AN-a-lyze | DIS-play", "instructions": "Survey question: 'What is your favorite subject in school?' Ask 6 people. Make a tally chart. Find the mode (most popular answer). Create a bar graph!", "tip": "Kwame says: A good survey starts with a clear, fair question. Check yours!"},
        "C": {"title": "Sound in Science", "time": 3, "img": "land7_time-in-music-rhythm.jpg", "img_alt": "Sound wave visualizations in Celestia science lab", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "SOWND | VY-BRAY-shun | WAVE | PITCH | VOL-yoom | EK-oh", "instructions": "Make a sound by tapping a table. Feel the vibration with your hand. Write: What is vibrating? What carries the sound to your ear? Draw a sound wave!", "tip": "Elias says: All sound is vibration. Your voice is just air vibrating. You make science every time you speak!"},
        "D": {"title": "Vitalis Music Movement", "time": 2, "img": "land1_music-instruments.jpg", "img_alt": "Children playing instruments and moving in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "RITH-um | BEETE | MOOOV | KLAP | STOMP | SWAY", "instructions": "Create your own body percussion piece: use clapping, stomping, and snapping. Make a 4-beat pattern. Repeat 4 times. Then teach it to someone!", "tip": "Nerissa says: Your body is the most portable instrument there is!"},
        "E": {"title": "Aquaria: Tricky English Words", "time": 2, "img": "land4_tricky-english-words.jpg", "img_alt": "Homophones and confusing English words illustrated", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "THER | THEIR | THEYRE | TO | TOO | TWO | HERE | HEAR", "instructions": "Write the difference between: there/their/they're and to/too/two. Write one sentence using all 3 versions of each set correctly!", "tip": "Selene says: English is full of word twins that sound alike but mean different things. Context is king!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "What sound fills your home most often? (laughter, music, TV, cooking?) Write 3 sentences about what that sound means to you."}}},
        {"week": 7, "day": 4, "day_label": "Thursday", "day_title": "Read, Write, Perform!", "primary_land": 1, "primary_land_color": "#d4a843", "primary_char_img": "AMARA.jpg", "primary_char_names": "Amara & Kwame", "blocks": {"A": {"title": "Study Skills & Strategies", "time": 3, "img": "land1_the-classroom.jpg", "img_alt": "Study skills posters in Harmonia classroom", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "STUD-ee | NOTE-TAKE | SUM-er-IZE | RE-call | TEST-PREP", "instructions": "Try the Cornell Notes method: Draw a vertical line 1/3 from the left. Write ideas on the right. Key words on the left. Summary at the bottom. Try it with today's lesson!", "tip": "Amara says: How you study matters more than how long you study. Study smarter!"},
        "B": {"title": "Fractions in Real Life", "time": 3, "img": "land2_fractions-decimals.jpg", "img_alt": "Fractions on a number line and in objects", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "FRAK-shun | DES-ih-mul | PER-sent | E-KWIV-uh-lent | COM-fair", "instructions": "Convert: 1/2 = ?% | 1/4 = ?% | 3/4 = ?%. Write 2 real-life examples of when you use fractions. Draw a number line showing: 0, 1/4, 1/2, 3/4, 1.", "tip": "Kwame says: Fractions, decimals, and percents are the same family in different clothes!"},
        "C": {"title": "Desert Animals Adaptations", "time": 3, "img": "land3_desert-dry-lands.jpg", "img_alt": "Desert survival adaptations in Terrasol arid zone", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "A-DAP-TAY-shun | SUR-vive | KAM-oh-flaj | STORE-wah-ter | NOK-tur-nal", "instructions": "Pick one desert animal. Write: 3 adaptations it has AND why each helps survival. Draw the animal in its habitat with labels.", "tip": "Vesta says: Adaptations make survival possible. Humans adapt too \u2014 think: coats in winter, sunscreen in summer!"},
        "D": {"title": "Vitalis Eye & Body Health", "time": 2, "img": "land5_eye-care-vision.jpg", "img_alt": "Eye exercises and vision health in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "EYE | BLINK | FOKE-us | NEAR | FAR | REST", "instructions": "Eye exercise: Look far (window) for 20 seconds, then near (fingers 12 inches away) for 20 seconds. Repeat 5 times. Your eyes should feel relaxed!", "tip": "Octavia says: Your eye muscles need exercise too. Train them gently every day!"},
        "E": {"title": "Sophia: Childcare & Parenting", "time": 2, "img": "land6_childcare-parenting.jpg", "img_alt": "Parents, children, and caregivers in Sophia community", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "CARE | PAR-ent | CHILD | SUP-port | LOVE | NEED | SAFE", "instructions": "Write 5 things a caregiver does for children. Write 3 things children can do to return kindness to their caregivers. Write a thank-you note!", "tip": "Felix says: Caregiving is one of the hardest and most important jobs. Say thank you today!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "FELIX.jpg", "char_names": "Felix & Athena"},
        "F": {"reflection_prompt": "Write a thank-you note to one person who took care of you this summer. Be specific \u2014 mention one thing they did that meant a lot."}}},
        {"week": 7, "day": 5, "day_label": "Friday", "day_title": "Week 7 Story Grand Finale!", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "EZRA.jpg", "primary_char_names": "Ezra & Elias", "blocks": {"A": {"title": "Study Skills Graduation", "time": 3, "img": "land1_school-events-activities.jpg", "img_alt": "Study skill celebration in Harmonia end of year", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "GRAD-yoo-ayt | READY | KON-fi-dent | TOOL | SKILL | GROW", "instructions": "List every study skill you've practiced this summer: (note-taking, Cornell notes, sight words, reading, etc.). Circle your top 3. Plan to keep practicing!", "tip": "Kwame says: Skills don't expire! Use what you learn this summer all year long!"},
        "B": {"title": "Math Story Creation", "time": 3, "img": "land2_charts-graphs.jpg", "img_alt": "A full math story problem project in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "CREE-ayt | PROB-lem | GRAPH | SOLVE | SHARE", "instructions": "Make your own illustrated math story problem book with 3 pages: page 1 = the story, page 2 = the math question with diagram, page 3 = the solution!", "tip": "Kwame says: Teaching math is the BEST way to learn it. Share your book with someone!"},
        "C": {"title": "Environment & Sustainability", "time": 3, "img": "land7_environment-sustainability.jpg", "img_alt": "Green earth and sustainability practices in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "SUS-TAYN-uh-bul | RENEW | KLEE-an | PROTECT | FUTURE | EARTH", "instructions": "Write your Personal Environmental Report: 3 eco-friendly things you already do, 3 you'll add, and 1 big change you wish the world would make.", "tip": "Elias says: You can't change everything, but you can change your part. That's how big change happens!"},
        "D": {"title": "Vitalis Summer Fitness Badge", "time": 2, "img": "land5_sports-fitness.jpg", "img_alt": "Fitness achievement ceremony in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "A-CHEEV | BADGE | STRONG | FIT | GROW | PROUD", "instructions": "Final fitness challenge: How many push-ups (on knees OK), sit-ups, and jumping jacks can you do in 1 minute each? Write your results. Then CELEBRATE!", "tip": "Nerissa says: Fitness is a lifelong gift you give yourself. Keep moving all year!"},
        "E": {"title": "Celestia Week 7 Review", "time": 2, "img": "land7_the-future-dreams.jpg", "img_alt": "Future dreamers celebrated in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "DREEM | PLAN | GOAL | ACTION | BE-LIEVE | FUTE-cher", "instructions": "Write YOUR summer story title, author (you!), and a 3-sentence summary. This is your memoir opening. Save it \u2014 you'll write the ending next week!", "tip": "Ezra says: Every great story has an author who kept going. You are that author!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "Elias & Ezra"},
        "F": {"reflection_prompt": "7 weeks! ONE week to go! Write: The story of my Summer Stretch, in exactly 7 words (one for each week)."}}
        }
      ]
    },
    {
      "week": 8,
      "theme": "Grand Celebration & Launch",
      "primary_land": 7,
      "days": [
        {"week": 8, "day": 1, "day_label": "Monday", "day_title": "All 7 Lands Recap", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "All Heroes Unite!", "blocks": {"A": {"title": "Land 1 Harmonia Recap", "time": 3, "img": "land1_greetings-introductions.jpg", "img_alt": "All Land 1 themes collaged in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "re-VIEW | HAR-mo-nee-uh | LANG-gwij | WORD | KOM-yoo-ni-kayt", "instructions": "From memory: Write 10 Land 1 vocab words (greetings, family, emotions, etc.). Use ALL 10 in a short paragraph about your summer life!", "tip": "Amara says: Language is your superpower. Use it!"},
        "B": {"title": "Land 2 Numeria Recap", "time": 3, "img": "land2_basic-math-operations.jpg", "img_alt": "All Land 2 math topics reviewed in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "re-VIEW | NU-mer-ee-uh | MATH | NUM-ber | SOL-ve", "instructions": "Solve one of each operation type: addition, subtraction, multiplication, division. Solve: 3/4 + 1/4 = ? Convert 75% to a fraction. Write one math story!", "tip": "Kwame says: Math isn't a subject. It's a way of thinking. Think like Numeria!"},
        "C": {"title": "Lands 3-5 Science Recap", "time": 3, "img": "land3_the-environment.jpg", "img_alt": "Nature, body, and science themes reviewed", "img_source": "SOE Picture Dictionary \u2014 Land 3,5", "phonetic": "re-VIEW | SY-ens | NA-cher | BOD-ee | EN-er-jee", "instructions": "Write 3 facts you learned each from: Terrasol (nature), Vitalis (health/body), Celestia (science/time). That's 9 amazing facts! Circle your favorite.", "tip": "Vesta says: Every fact you remember is a tool for your future. Keep building!"},
        "D": {"title": "Grand Fitness Challenge", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "Olympic-style fitness events in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "CHAL-enj | BEST | TRY | BEAT | PER-sonal-REC-ord", "instructions": "Try your personal best: Hold a plank for as long as possible. Write the time. Compare to Week 1 (if you tracked it). You have grown stronger!", "tip": "Nerissa says: Fitness growth is quiet but real. Look how far you've come!"},
        "E": {"title": "Lands 4 & 6 Social Studies Recap", "time": 2, "img": "land4_geography-landforms.jpg", "img_alt": "World geography and community overview", "img_source": "SOE Picture Dictionary \u2014 Lands 4,6", "phonetic": "re-VIEW | GEO-gruh-fee | COM-yoo-nih-tee | SIV-iks | WORLD", "instructions": "Write 3 geography facts (from Land 4) and 3 civic facts (from Land 6) you remember. Draw one thing that represents each land for you personally.", "tip": "Ronan says: Social studies is the study of YOU and your world together. You ARE the subject!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "All Heroes"},
        "F": {"reflection_prompt": "Which of the 7 Lands is your favorite? Write 3 reasons. Which hero do you identify with most? Why?"}}},
        {"week": 8, "day": 2, "day_label": "Tuesday", "day_title": "Showcase Prep Day", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "EZRA.jpg", "primary_char_names": "Ezra & All Heroes", "blocks": {"A": {"title": "My Summer Word Collection", "time": 3, "img": "land1_personal-information.jpg", "img_alt": "A personal vocabulary book in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "KOL-ekt | VOCAB-yoo-lair-ee | MINE | GREW | LERN-ed", "instructions": "Flip through your workbook. Find 20 words you learned this summer. Copy them into a Word Collection page. Sort by: land, type, or difficulty!", "tip": "Amara says: Collecting words is collecting power. Your word count grew this summer!"},
        "B": {"title": "Math Portfolio Review", "time": 3, "img": "land2_charts-graphs.jpg", "img_alt": "Math achievement showcase in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "PORT-fo-lee-oh | re-VIEW | BEST | PROOF | SHOW", "instructions": "Look through your math work. Choose your BEST problem. Copy it neatly on this page with full solution steps. Add a title: 'My Best Math Moment!'", "tip": "Kwame says: A portfolio shows growth over time. Looking back = looking forward with wisdom!"},
        "C": {"title": "Science Journal Review", "time": 3, "img": "land7_the-scientific-method.jpg", "img_alt": "Science discoveries recorded in Celestia journal", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "JER-nul | re-VIEW | DIS-kover | RECORD | GROW | LEAR-n", "instructions": "Write a science discovery journal entry for your BEST science observation this summer. Include: question, what you saw, what you learned, one more question!", "tip": "Elias says: A science mind never stops asking 'Why?' or 'What if?'"},
        "D": {"title": "Vitalis Showcase Warm-Up", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "Children warming up for a showcase event in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "WARM-up | SHOW-case | PER-form | ENER-jee | STRONG", "instructions": "Create a 2-minute warm-up routine for your Summer Showcase. Include: 3 stretches, 3 strength moves, and a final pose. Name and practice it!", "tip": "Octavia says: A great presentation starts with a confident, energized body!"},
        "E": {"title": "Sophia: Resume Basics", "time": 2, "img": "land6_resume-applications.jpg", "img_alt": "A resume template in Sophia career center", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "REZ-yoo-may | SKILL | EX-peer-ee-ens | ACHIEV-ment | GOAL", "instructions": "Write a 'Student Resume' for yourself: Name, Grade, 3 Strengths, 2 Things I Improved This Summer, 1 Goal for Next Year. Make it look professional!", "tip": "Athena says: A resume is a story of your best self. Start growing that story now!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "Design the cover of your Summer Stretch memory book. Draw it in the box and write the title in your best handwriting."}}},
        {"week": 8, "day": 3, "day_label": "Wednesday", "day_title": "Quest Map Final Update", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "Elias, Ezra & All", "blocks": {"A": {"title": "My Summer Stretch Story", "time": 3, "img": "land1_school-events-activities.jpg", "img_alt": "Children celebrating learning accomplishments in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "STORY | BEGIN | MID-ul | END | de-TAIL-s | PROUD", "instructions": "Write your complete Summer Stretch Story: beginning (how you started), middle (your biggest challenge), end (what you learned). Aim for 8-10 sentences!", "tip": "Amara says: Every learner has a hero's story. You are the hero of yours!"},
        "B": {"title": "Math Celebration Problems", "time": 3, "img": "land2_money-currency.jpg", "img_alt": "Celebration math puzzles in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "SEL-eh-brayt | SOL-ve | FUN | CHAL-enj | REWARD", "instructions": "Celebration problems: If this workbook has 8 weeks, 5 days/week, 6 blocks/day, how many total activities did you complete? Show your multiplication!", "tip": "Kwame says: 240 activities in 8 weeks! That's an army of brain cells you've built!"},
        "C": {"title": "Celestia Calendar of Dreams", "time": 3, "img": "land7_the-calendar-cycles.jpg", "img_alt": "A beautiful year-long calendar in Celestia observatory", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "CAL-en-der | CYCLE | PLAN | DIS-ciplin | GOAL | DREAM", "instructions": "Mark your school year calendar with 4 big goals: one per quarter. Write each as: 'By [month], I will have ___.' Sign and date it as a contract with yourself!", "tip": "Ezra says: A written goal is a commitment. A committed learner is unstoppable!"},
        "D": {"title": "Vitalis Vitality Dance", "time": 2, "img": "land5_sports-fitness.jpg", "img_alt": "End of summer celebration dance in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "SEL-eh-brayt | MOVE | JOY | DANCE | ENER-jee | FREE", "instructions": "Celebration dance: play your favorite song. Dance as if you just finished 8 weeks of amazing learning (because you did!). No rules. Just joy!", "tip": "Nerissa says: You earned this dance. Move with pride, Summer Stretch Champion!"},
        "E": {"title": "Aquaria: My World Map", "time": 2, "img": "land4_map-reading-gps.jpg", "img_alt": "A personal world map in Aquaria cartography center", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "WORLD | MAP | KON-tih-nent | COUN-tree | PLACE | ME", "instructions": "Draw a simple world map. Mark: where you live with a star, one place an ancestor came from, and one place you dream of visiting. Label all 3!", "tip": "Selene says: Every person is a world traveler in their heart. Dream maps become real maps!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "Draw your Quest Map completely filled in \u2014 all 8 lands explored! Write your QUEST MOTTO: the words you'll carry with you into the school year."}}},
        {"week": 8, "day": 4, "day_label": "Thursday", "day_title": "Letters & Legacy", "primary_land": 1, "primary_land_color": "#d4a843", "primary_char_img": "AMARA.jpg", "primary_char_names": "Amara & All Heroes", "blocks": {"A": {"title": "Letter to Future Me", "time": 3, "img": "land1_personal-information.jpg", "img_alt": "A letter-writing ceremony in Harmonia square", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "LET-er | FU-cher | PROM-ice | GOAL | RE-MEM-ber", "instructions": "Write a letter to yourself to open on the FIRST DAY of school. Tell future-you: what you learned, what you're proud of, and 3 goals for the school year!", "tip": "Amara says: Letters to your future self are the kindest thing you can write. Be gentle and encouraging!"},
        "B": {"title": "Numbers I Know", "time": 3, "img": "land2_numbers-counting.jpg", "img_alt": "Number achievement wall in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "COUNT | MATH-FACTS | FRACTIONS | MEAS-ure | DATA | proud", "instructions": "Write your math highlight reel: best addition fact, fastest multiplication, hardest problem you solved, coolest pattern you found, favorite data you collected.", "tip": "Kwame says: Math highlighets show you your strengths. Celebrate each one!"},
