          "primary_char_img": "AMARA.jpg",
          "primary_char_names": "Amara & Kwame",
          "blocks": {
            "A": {
              "title": "Word Detectives: Greetings",
              "time": 3,
              "img": "land1_greetings-introductions.jpg",
              "img_alt": "Children waving hello in Harmonia village",
              "img_source": "SOE Picture Dictionary \u2014 Land 1",
              "phonetic": "heh-LOW | hye | GUD-mor-ning",
              "instructions": "Look at the picture. Find 3 greeting words. Trace each one, then write it yourself below.",
              "tip": "Amara says: When you learn a new greeting, practice it with your whole face \u2014 smile big!"
            },
            "B": {
              "title": "Numeria Number Hunt",
              "time": 3,
              "img": "land2_numbers-counting.jpg",
              "img_alt": "Number tiles and counting beads in Numeria",
              "img_source": "SOE Picture Dictionary \u2014 Land 2",
              "phonetic": "WUN | TOO | THREE | FOR | FIEV",
              "instructions": "Count the objects in the picture. Write the total in each box. Circle the biggest number.",
              "tip": "Kwame says: Use your finger to count carefully. Slow and steady wins the math race!"
            },
            "C": {
              "title": "Terrasol Garden Secrets",
              "time": 3,
              "img": "land3_seeds-growing.jpg",
              "img_alt": "Seeds sprouting in Terrasol garden",
              "img_source": "SOE Picture Dictionary \u2014 Land 3",
              "phonetic": "SEED | ROOT | SPROUT | LEEF | SUN",
              "instructions": "Draw a seed under the soil and a sprout above it. Label 3 parts: seed, root, sprout.",
              "tip": "Silas says: Every giant tree started as a tiny seed \u2014 just like every big reader started with one word!"
            },
            "D": {
              "title": "Vitalis Wake-Up Move",
              "time": 2,
              "img": "land5_exercise-movement.jpg",
              "img_alt": "Children stretching in Vitalis",
              "img_source": "SOE Picture Dictionary \u2014 Land 5",
              "phonetic": "STRETCH | JUMP | BREETH | MOOV",
              "instructions": "Stand up! Do 5 arm circles forward, 5 backward. Take 3 deep breaths. Shake out your hands. You're ready to learn!",
              "tip": "Nerissa says: Your brain learns better when your body moves first!"
            },
            "E": {
              "title": "Aquaria Map Adventure",
              "time": 2,
              "img": "land4_geography-landforms.jpg",
              "img_alt": "Mountains, rivers, and plains on an Aquaria map",
              "img_source": "SOE Picture Dictionary \u2014 Land 4",
              "phonetic": "MOWN-tin | RIV-er | PLAYN | oh-SHUN",
              "instructions": "Look at the landform picture. Can you find a mountain? A river? Draw your own simple map with 2 landforms and label them.",
              "tip": "Ronan says: Maps are stories about places. Every map tells you something new!",
              "land": 4,
              "land_class": "land4",
              "land_name": "Aquaria",
              "icon": "\ud83c\udf0a",
              "subject": "Geography",
              "char_img": "RONAN.jpg",
              "char_names": "Ronan & Selene"
            },
            "F": {
              "reflection_prompt": "What was your favorite activity today? Draw a star next to it and write one word that describes how you feel right now."
            }
          }
        },
