            "B": {"title": "Fractions Fun", "time": 3, "img": "land2_fractions-decimals.jpg", "img_alt": "Fractions shown with shapes and food", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "FRAK-shun | HALF | QWAR-ter | THIRD | WHOLE", "instructions": "Fold a piece of paper in half. That's 1/2! Fold again \u2014 that's 1/4! Draw and label: 1 whole, 1/2, 1/4 of a circle.", "tip": "Kwame says: Cutting a pizza = fractions! You already know more math than you think!"},
            "C": {"title": "Insects & Bugs Field Guide", "time": 3, "img": "land3_insects-bugs.jpg", "img_alt": "Colorful insects illustrated in Terrasol meadow", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "IN-sekt | BUT-er-fly | BEE | ANT | CRICK-et | LEG", "instructions": "Find an insect in the picture. Write: name, number of legs, wings (yes/no), where it lives. Compare with a second insect!", "tip": "Silas says: All insects have 6 legs. Use that to tell bugs from spiders!"},
            "D": {"title": "Vitalis Jump Circuit", "time": 2, "img": "land5_sports-fitness.jpg", "img_alt": "Children doing jumping exercises in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "JUM | HOP | SKIP | LAND | BAL-ens", "instructions": "Complete the circuit: 10 jumping jacks, 5 hops on each foot, 10 skips (alternate feet). Rest. Repeat if you have energy!", "tip": "Nerissa says: Circuits build heart strength AND coordination. Go go go!"},
            "E": {"title": "Aquaria: Directions", "time": 2, "img": "land4_directions-navigation.jpg", "img_alt": "Street signs and direction arrows in Aquaria city", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "LEST | RITE | STRATE | TER-n | FOR-werd | BACK", "instructions": "Give directions from your room to the kitchen using: left, right, straight, turn. Draw the route like a top-view map.", "tip": "Selene says: Knowing directions keeps you from getting lost. Be your own map!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
            "F": {"reflection_prompt": "If you could paint a mural of your favorite land, which one would you choose? Sketch a tiny version here."}
          }
        },
        {
          "week": 2, "day": 4, "day_label": "Thursday", "day_title": "Manners & Money",
          "primary_land": 1, "primary_land_color": "#d4a843",
          "primary_char_img": "AMARA.jpg", "primary_char_names": "Amara & Kwame",
          "blocks": {
            "A": {"title": "Manners Matter", "time": 3, "img": "land1_manners-politeness.jpg", "img_alt": "Children being polite in Harmonia market", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "PL\u012aZ | THANK-yoo | EK-SKYOOZ-mee | SOR-ee | WEL-kum", "instructions": "Write 5 polite phrases from the picture. Practice saying each one aloud. Write one sentence using 2 of these phrases.", "tip": "Amara says: Kind words open every door. Practice them today!"},
            "B": {"title": "Money Makes Sense", "time": 3, "img": "land2_money-currency.jpg", "img_alt": "Coins and bills in Numeria market stalls", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "COIN | BIL | CENT | DOL-er | PRICE | CHANJE", "instructions": "If you have $1.00 and a candy costs $0.35, how much change do you get? Draw the coins you'd receive. Try with $0.75 too!", "tip": "Kwame says: Being good with money starts with learning to count it!"},
            "C": {"title": "Fruits & Vegetables Lab", "time": 3, "img": "land3_fruits-vegetables.jpg", "img_alt": "Colorful produce in a Terrasol farmer's market", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "FROOT | VEJ-ih-tuh-bul | SEED | SKIN | JOO-see", "instructions": "Sort these into Fruit or Vegetable: apple, carrot, banana, broccoli, mango, spinach. How do you know which is which? Write your rule.", "tip": "Vesta says: A fruit has seeds inside. A vegetable is a stem, leaf, or root. Check your rule!"},
            "D": {"title": "Vitalis Mindful Moment", "time": 2, "img": "land5_mental-health-emotions.jpg", "img_alt": "Children breathing and being mindful in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "MIND-ful | BREETH | KAM | FO-kus | PEE-ful", "instructions": "Sit up straight. Close your eyes. Breathe in slowly \u2014 4 counts. Hold \u2014 2 counts. Out slowly \u2014 6 counts. Do this 3 times. How do you feel?", "tip": "Octavia says: 3 mindful breaths can change your whole mood. Science says so!"},
            "E": {"title": "Sophia: Types of Workers", "time": 2, "img": "land6_types-of-workers.jpg", "img_alt": "Many occupations illustrated in Sophia city", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "WER-ker | JOB | OC-yoo-PAY-shun | SKILL | EARN", "instructions": "Pick 2 workers from the picture. Write: Job Name, What they do, What skills they need. Which job would you choose?", "tip": "Athena says: Every job is important. Community works because people share responsibilities!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "FELIX.jpg", "char_names": "Felix & Athena"},
            "F": {"reflection_prompt": "What is one way you showed good manners today? Write it down. Good manners are a superpower!"}
          }
        },
        {
          "week": 2, "day": 5, "day_label": "Friday", "day_title": "Week 2 Quest Complete!",
          "primary_land": 7, "primary_land_color": "#9678c4",
          "primary_char_img": "EZRA.jpg", "primary_char_names": "Ezra & Elias",
          "blocks": {
            "A": {"title": "Hobby & Hobbies Page", "time": 3, "img": "land1_hobbies-recreation.jpg", "img_alt": "Children enjoying hobbies in Harmonia park", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "HOB-ee | PLAY | DRAW | READ | DAN-s | SPORT", "instructions": "Write 5 hobbies from the picture. Circle your favorite. Write 3 sentences: 'I love to ___ because ___.'", "tip": "Kwame says: Hobbies feed your soul and grow your skills. Protect your hobbies!"},
            "B": {"title": "Estimation Challenge", "time": 3, "img": "land2_estimation-comparison.jpg", "img_alt": "Estimation jars and comparison problems", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "ES-tih-MAY-shun | MORE | LES | A-BOUT | KWOZ-ee", "instructions": "Grab a handful of small objects (coins, beans, buttons). Estimate first, then count. Write: My estimate ___, Actual count ___, Difference ___.", "tip": "Kwame says: Estimation is making a smart guess. The best estimators count the most carefully!"},
            "C": {"title": "Rocks & Minerals Study", "time": 3, "img": "land3_rocks-minerals.jpg", "img_alt": "Colorful rocks and crystals in Terrasol caves", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "ROK | MIN-er-ul | KRIS-tul | SMOOTH | ROUGH | HARD", "instructions": "Find 2 rocks near you (outside or in a picture). Describe each: Color, Texture (smooth/rough), Weight (heavy/light), Shiny or dull.", "tip": "Silas says: Every rock tells the story of where it's been. Rocks are Earth's diary!"},
            "D": {"title": "Vitalis Rest & Recovery", "time": 2, "img": "land5_sleep-rest.jpg", "img_alt": "Healthy sleep habits and rest in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "SLEEP | REST | DREEM | RE-cover | EN-er-jee", "instructions": "How many hours did you sleep last night? Kids need 9-11 hours! Write your bedtime routine: 3 steps that help you sleep well.", "tip": "Nerissa says: Sleep = brain recharge. Your brain sorts and saves memories while you sleep!"},
            "E": {"title": "Celestia Week 2 Review", "time": 2, "img": "land7_the-scientific-method.jpg", "img_alt": "Stars and reflection tools in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "re-FLEKT | re-VIEW | GROW | LERND | NEXT-WEEK", "instructions": "Draw your Week 2 highlight. Write: 1 thing I learned, 1 thing I want to learn more about, 1 way I grew as a learner this week.", "tip": "Ezra says: Reflection turns experience into wisdom. Future-you thanks present-you!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "Elias & Ezra"},
            "F": {"reflection_prompt": "Color the Quest Map star for Week 2. You earned it! Write one word that describes your summer quest so far."}
          }
        }
      ]
    },
    {
      "week": 3,
      "theme": "Community & Cooperation",
      "primary_land": 6,
      "days": [
        {"week": 3, "day": 1, "day_label": "Monday", "day_title": "Neighborhood Explorers", "primary_land": 6, "primary_land_color": "#5ba4c9", "primary_char_img": "FELIX.jpg", "primary_char_names": "Felix & Athena", "blocks": {"A": {"title": "The Neighborhood", "time": 3, "img": "land1_the-neighborhood.jpg", "img_alt": "Streets, parks and shops in Harmonia neighborhood", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "NAIB-er | STREET | PARK | STORE | LIB-ruh-ree", "instructions": "Write 6 neighborhood places from the picture. Which one do you visit most? Draw your street and label 3 places.", "tip": "Amara says: Your neighborhood is your first world. Know every part of it!"},
        "B": {"title": "Problem Solving Logic", "time": 3, "img": "land2_problem-solving-logic.jpg", "img_alt": "Logic puzzles in Numeria classroom", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "PROB-lem | SOL-ve | STEP | THINK | AN-ser", "instructions": "Read: There are 12 apples. 4 children each want the same amount. How many does each child get? Show your work in 3 steps!", "tip": "Kwame says: Every math problem is a puzzle waiting to be solved step by step!"},
        "C": {"title": "The Environment Project", "time": 3, "img": "land3_the-environment.jpg", "img_alt": "Clean rivers and forests in Terrasol", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "en-VY-ron-ment | PO-loo-shun | PRO-tekt | NA-tur | KLEEN", "instructions": "Draw a before/after: one side shows a polluted environment, the other shows a clean one. Write 2 things YOU can do to help.", "tip": "Vesta says: The environment is everyone's home. Protect what you love!"},
        "D": {"title": "Vitalis Team Fitness", "time": 2, "img": "land5_sports-fitness.jpg", "img_alt": "Team sports and cooperation in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "TEEM | CO-op-er-ayt | SPORT | PASS | CHEER", "instructions": "Play mirror game: stand facing a partner or mirror. One person leads slow movements. Switch! Leaders: be creative. Followers: be precise!", "tip": "Nerissa says: Sports teach us to work together AND listen carefully!"},
        "E": {"title": "Aquaria: Community Places", "time": 2, "img": "land4_community-places.jpg", "img_alt": "Community buildings from a bird's eye view in Aquaria", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "SKOOL | HOS-pih-tul | LIB-ruh-ree | POST-of-is | PARK", "instructions": "Write 4 community places. Write why each one is important. Which one would be hardest to live without? Defend your answer!", "tip": "Ronan says: Community places are shared treasure. Take care of them!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "What makes a good neighbor? Write 3 qualities. Are you that kind of neighbor? Circle: Yes / Working on it / Not yet \u2014 then make a plan!"}}},
        {"week": 3, "day": 2, "day_label": "Tuesday", "day_title": "Jobs & Journeys", "primary_land": 6, "primary_land_color": "#5ba4c9", "primary_char_img": "ATHENA.jpg", "primary_char_names": "Athena & Felix", "blocks": {"A": {"title": "Communication Tech", "time": 3, "img": "land1_communication-technology.jpg", "img_alt": "Phones, computers and letters in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "FONE | KOM-pyu-ter | EM-ayl | LET-er | MES-ij", "instructions": "List 5 ways people communicate from the picture. Old or New? Mark each O (old) or N (new). Which way do you use most?", "tip": "Amara says: Communication connects us to the world. Choose your words carefully!"},
        "B": {"title": "The Grocery Store Math", "time": 3, "img": "land2_the-grocery-store-shopping.jpg", "img_alt": "Shopping at a busy Numeria market", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "PRICE | BUD-jet | CHANGE | LIST | COM-pair", "instructions": "Make a grocery list for a pretend party. Write 5 items with prices. Calculate the total. You have $10 \u2014 can you afford it all?", "tip": "Kwame says: Shopping on a budget is real math. You're a financial superstar!"},
        "C": {"title": "Farm to Table Journey", "time": 3, "img": "land3_farm-to-table.jpg", "img_alt": "Crops being harvested and brought to market", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "FARM | HAR-vest | TRANS-port | STORE | COOK | EET", "instructions": "Draw the journey of a tomato: seed \u2192 plant \u2192 harvest \u2192 store \u2192 your plate! Label each step with an action word.", "tip": "Silas says: Understanding where food comes from makes every meal more meaningful!"},
        "D": {"title": "Vitalis First Aid Basics", "time": 2, "img": "land5_first-aid-injuries.jpg", "img_alt": "First aid kit and basic injury care in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "FERST-AYD | BAND-AYJ | ICE | WASH | HELP", "instructions": "Write what you should do for: a small cut, a bruise, a burn. Write STOP, LOOK, THINK before each answer. Ask a adult to check!", "tip": "Octavia says: Knowing first aid is knowing how to help. Be a helper!"},
        "E": {"title": "Sophia: Occupations", "time": 2, "img": "land6_occupations-careers.jpg", "img_alt": "Workers in different careers in Sophia", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "OK-yoo-PAY-shun | CAREER | SKILL | TRAIN | EARN", "instructions": "Pick your dream career from the picture. Write: Job name, 3 skills needed, 1 reason you'd love it. Interview yourself in 3 Q&As!", "tip": "Felix says: Exploring career options now helps you dream bigger later!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "If you could help your community in ANY way, what would you do? Write your community superpower!"}}},
        {"week": 3, "day": 3, "day_label": "Wednesday", "day_title": "Music & Movement", "primary_land": 1, "primary_land_color": "#d4a843", "primary_char_img": "AMARA.jpg", "primary_char_names": "Amara & Kwame", "blocks": {"A": {"title": "Music Instruments", "time": 3, "img": "land1_music-instruments.jpg", "img_alt": "Musical instruments displayed in Harmonia stage", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "GYTAR | PYAN-oh | DRUM | FLO\u014aT | VY-oh-lin", "instructions": "Write 5 instrument names. Sort them: String, Wind, or Percussion. Which one sounds like a heartbeat? Which like the wind?", "tip": "Amara says: Music is the universal language. It needs no translation!"},
        "B": {"title": "Distance & Speed", "time": 3, "img": "land2_distance-speed.jpg", "img_alt": "Race tracks and speed charts in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "DIS-tans | SPEED | FAST | SLOW | MILE | KIL-oh-ME-ter", "instructions": "If you walk 3 steps per second, how many steps in 10 seconds? 30 seconds? 1 minute? Now time yourself walking 20 steps. How fast?", "tip": "Kwame says: Speed = distance \u00f7 time. You just did physics!"},
        "C": {"title": "Trees of the Forest", "time": 3, "img": "land3_trees-the-forest.jpg", "img_alt": "Tall trees and forest floor in Terrasol", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "TREE | BARK | BRANCH | LEEF | ROOT | SAP", "instructions": "Go outside or look at a tree image. Write 5 tree parts. Draw a tree and label all 5 parts. What animals might live in this tree?", "tip": "Vesta says: One tree can be home to hundreds of creatures. Trees are apartment buildings!"},
        "D": {"title": "Vitalis Dance Break", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "Children dancing freely in Vitalis studio", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "DAN-s | RITH-um | BEET | MOV | FEEL", "instructions": "Play your favorite song. Dance freely for the whole song! No rules. Move every part of your body. When it ends, breathe and smile.", "tip": "Nerissa says: Dance is exercise disguised as joy. Sneak in the movement!"},
        "E": {"title": "Aquaria: Weather & Climate", "time": 2, "img": "land4_weather-climate.jpg", "img_alt": "Climate zones shown on a world map", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "KLY-mut | ZONE | TRO-pik-ul | DES-ert | PO-ler", "instructions": "Find 3 climate zones in the picture. Write the zone name and 2 things plants/animals need to survive there.", "tip": "Selene says: Climate is the personality of a place \u2014 the weather it usually has!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "Hum or sing 3 notes right now. You just made music! Write: How did it feel to make sound with your voice?"}}},
        {"week": 3, "day": 4, "day_label": "Thursday", "day_title": "Safety & Science", "primary_land": 3, "primary_land_color": "#10B981", "primary_char_img": "SILAS.jpg", "primary_char_names": "Silas & Vesta", "blocks": {"A": {"title": "School Events & Activities", "time": 3, "img": "land1_school-events-activities.jpg", "img_alt": "School fair, science day and field trip in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "SKOOL-FAIR | SY-ens-DAY | FEELD-TRIP | GRAD-yoo-A-shun", "instructions": "Write 4 school events from the picture. Which is your favorite and why? Write 3 sentences using: first, next, finally.", "tip": "Amara says: School events build community. Show up for your people!"},
        "B": {"title": "Budget & Savings", "time": 3, "img": "land2_budget-savings.jpg", "img_alt": "A piggy bank and savings chart in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "BUD-jet | SAVE | SPEND | EARN | GOL", "instructions": "You earn $5 per week for chores. You want a $20 toy. How many weeks to save? Plan your budget: Save $___, Spend $___ each week.", "tip": "Kwame says: Savers are powerful! Future-you will thank present-you!"},
        "C": {"title": "Rivers & Lakes Science", "time": 3, "img": "land3_rivers-lakes.jpg", "img_alt": "River systems and lake ecology in Terrasol", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "RIV-er | LAYK | STREAM | BANKE | FLOW | FRESH-wah-ter", "instructions": "Write how a river is different from a lake. Now draw a river with: source, bank, current, and mouth. Label all 4 parts!", "tip": "Silas says: Rivers are nature's highways. They've carried people and goods for thousands of years!"},
        "D": {"title": "Vitalis Personal Care", "time": 2, "img": "land5_personal-care-products.jpg", "img_alt": "Personal care products laid out in Vitalis bathroom", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "SOAP | SHAM-poo | TOOTH-brUSH | DE-od-or-ant | COMB", "instructions": "Write a 5-step hygiene routine for morning. Write a 3-step routine for bedtime. Circle one habit you want to build this summer.", "tip": "Octavia says: Personal care = self-respect in action!"},
        "E": {"title": "Sophia: Safety & Emergencies", "time": 2, "img": "land6_safety-emergencies.jpg", "img_alt": "Emergency procedures and safety signs in Sophia", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "E-mer-jen-see | SAFE | KALL | HELP | EK-zit | FYRE", "instructions": "Write your home address and a trusted adult's phone number (with their permission). Practice saying: 'My name is ___, my address is ___.'", "tip": "Felix says: Knowing your address could save your life one day!",  "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "FELIX.jpg", "char_names": "Felix & Athena"},
        "F": {"reflection_prompt": "Write 3 safety rules you follow. Why is each one important? Who taught you these rules? Say thank you to that person today."}}},
        {"week": 3, "day": 5, "day_label": "Friday", "day_title": "Week 3 Celebration!", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "EZRA.jpg", "primary_char_names": "Ezra & Elias", "blocks": {"A": {"title": "Playground Vocabulary", "time": 3, "img": "land1_the-playground-recess.jpg", "img_alt": "Playground equipment and children playing in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "SLIDE | SWING | CLIMB | RUN | FRIEND", "instructions": "Write 6 playground words. Use 3 of them in a story about your best recess ever. Include a beginning, middle, and end.", "tip": "Kwame says: Great stories have a problem AND a solution. What's the problem at recess?"},
        "B": {"title": "Data & Statistics", "time": 3, "img": "land2_data-statistics.jpg", "img_alt": "Charts and graphs showing data in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "DAY-tuh | AVER-ij | MODE | RANGE | SUR-vay", "instructions": "Survey 5 people: How many hours of TV did you watch yesterday? Find the average (add all \u00f7 5). Now make a bar graph!", "tip": "Kwame says: Data tells stories that words can't always tell. Be a data detective!"},
        "C": {"title": "Camping & Hiking Adventure", "time": 3, "img": "land3_camping-hiking.jpg", "img_alt": "Campers with gear in the Terrasol wilderness", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "CAMP | HIKE | TENT | TRAIL | PACK | FIRE-place", "instructions": "Pack your imaginary backpack for a 1-day hike! Write 8 essential items. Explain why each is important using 'because'.", "tip": "Vesta says: Preparation is the most important outdoor skill. Prepare well, hike safely!"},
        "D": {"title": "Vitalis Eye Care", "time": 2, "img": "land5_eye-care-vision.jpg", "img_alt": "Eye health and vision care in Vitalis clinic", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "EYE | VI-zhun | GLASS-ez | BLINK | CHART", "instructions": "Take an eye break: Look away from this page for 20 seconds. Blink 10 times. Focus on something far away. How do your eyes feel?", "tip": "Nerissa says: The 20-20-20 rule: every 20 min, look 20 feet away for 20 seconds. Protect your eyes!"},
        "E": {"title": "Celestia Week 3 Review", "time": 2, "img": "land7_the-future-dreams.jpg", "img_alt": "Children dreaming about the future in Celestia", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "DREEM | FU-cher | GOAL | HOPE | PLAN | GROW", "instructions": "Draw your future self doing your dream job. Write: Age I'll be, Job title, One skill I need to learn to get there!", "tip": "Ezra says: Dreams become plans when you write them down. Write yours TODAY!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "Elias & Ezra"},
        "F": {"reflection_prompt": "3 weeks done! Color 3 stars on your Quest Map. Write: The best thing about this summer stretch so far is ___"}}}
