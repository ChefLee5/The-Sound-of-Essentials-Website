              "land_class": "land4",
              "land_name": "Aquaria",
              "icon": "\ud83c\udf0a",
              "subject": "Geography",
              "char_img": "RONAN.jpg",
              "char_names": "Ronan & Selene"
            },
            "F": {
              "reflection_prompt": "What did you learn today that surprised you? Write one sentence and add 3 stars if you're proud of your work."
            }
          }
