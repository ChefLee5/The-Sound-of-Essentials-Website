              "phonetic": "RITE | doo-TEE | re-SPON-sih-BIL-ih-tee",
              "instructions": "A right is something you have. A duty is something you do. Write 1 right and 1 duty you have at home. Share with someone!",
              "tip": "Felix says: Good citizens know their rights AND their responsibilities.",
              "land": 6,
              "land_class": "land6",
              "land_name": "Sophia",
              "icon": "\u2696\ufe0f",
              "subject": "Civics",
              "char_img": "FELIX.jpg",
              "char_names": "Felix & Athena"
            },
            "F": {
              "reflection_prompt": "Draw your face right now. Are you happy, tired, focused, or excited? Write the word under your drawing."
            }
          }
        },
