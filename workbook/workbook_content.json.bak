      "week": 4,
      "theme": "Wonders of the World",
      "primary_land": 4,
      "days": [
        {"week": 4, "day": 1, "day_label": "Monday", "day_title": "Transportation Around the World", "primary_land": 4, "primary_land_color": "#2563EB", "primary_char_img": "RONAN.jpg", "primary_char_names": "Ronan & Selene", "blocks": {"A": {"title": "Celebrations Around the World", "time": 3, "img": "land1_celebrations-traditions.jpg", "img_alt": "Festivals and celebrations from different cultures in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "SEL-eh-BRAY-shun | TRA-dish-un | FES-tih-vul | CUS-tum", "instructions": "Find 3 celebrations in the picture. Write each name and one thing people do during it. Share: what is a celebration from YOUR culture?", "tip": "Amara says: Every culture's celebrations are beautiful. Curiosity = respect!"},
        "B": {"title": "Weight & Measurement", "time": 3, "img": "land2_weights-measures.jpg", "img_alt": "Scales and metric units in Numeria workshop", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "WATE | POUND | KILO | SCALE | LIB-re", "instructions": "Find 5 objects at home. Estimate: heavier or lighter than a shoe? Now check by lifting both. Were your estimates right?", "tip": "Kwame says: Estimation gets better with practice. Every wrong guess teaches you!"},
        "C": {"title": "Desert Dry Lands", "time": 3, "img": "land3_desert-dry-lands.jpg", "img_alt": "Cacti and desert animals in a Terrasol dry zone", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "DES-ert | KAK-tus | SAND | DRY | SUR-vive", "instructions": "Write 3 desert adaptations plants OR animals use to survive. Draw a desert scene with at least 2 living things labeled.", "tip": "Silas says: Desert creatures are survival experts. What can we learn from them?"},
        "D": {"title": "Vitalis Outdoor Moves", "time": 2, "img": "land5_exercise-movement.jpg", "img_alt": "Outdoor physical activities in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "HIKE | KART-WHEEL | KLIM | WADE | EK-splore", "instructions": "Go outside (or open a window). Do 10 jumping jacks, 5 push-ups against a wall, and hold a balance pose for 10 seconds each leg!", "tip": "Nerissa says: Fresh air + movement = the best learning fuel!"},
        "E": {"title": "Aquaria: Transportation", "time": 2, "img": "land4_transportation.jpg", "img_alt": "Trains, planes, and ships in the Aquaria world", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "TRANS-port | PLANE | TRAIN | SHIP | BUS | KAR", "instructions": "List 5 types of transport. Write: Land, Water, or Air? Which is fastest? Draw your favorite and write one fact about it!", "tip": "Ronan says: Transportation shrinks the world. How many places can you reach in a day?", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "If you could travel to any country in the world, where would you go? Write 3 things you would see, eat, or do there."}}},
        {"week": 4, "day": 2, "day_label": "Tuesday", "day_title": "Banking & Borrowing", "primary_land": 2, "primary_land_color": "#7fb685", "primary_char_img": "KWAME.jpg", "primary_char_names": "Kwame & Amara", "blocks": {"A": {"title": "Colors in Clothing", "time": 3, "img": "land1_clothing-getting-dressed.jpg", "img_alt": "Clothing items for different seasons in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "SHIRT | PANTS | DRESS | SOKS | SHOES | JAK-et", "instructions": "Write 8 clothing items from the picture. Sort by: Hot weather / Cold weather / Any weather. What are you wearing right now? List 5 items.", "tip": "Kwame says: Dressing for the weather is practical science!"},
        "B": {"title": "The Bank & Finances", "time": 3, "img": "land2_the-bank.jpg", "img_alt": "A bank and financial services in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "BANK | SAV-ings | A-KOUNT | DE-poz-it | WITH-draw", "instructions": "You deposit $10 on Monday. Withdraw $3 on Wednesday. Deposit $5 on Friday. What's your balance? Show your work like a bank statement!", "tip": "Kwame says: A bank is just a safe place for your savings that also pays you interest!"},
        "C": {"title": "Inside the Body", "time": 3, "img": "land5_inside-the-body.jpg", "img_alt": "Body system diagrams in Vitalis medical center", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "HART | LUNG | STOM-ak | BRANE | BONE | MUS-ul", "instructions": "Match the organ to its job: Heart (pumps blood), Lungs (breathe air), Stomach (digests food), Brain (thinks & controls). Draw and label!", "tip": "Octavia says: You have an entire system working for you right now. Thank your body!"},
        "D": {"title": "Vitalis Dental Health", "time": 2, "img": "land5_the-dentist.jpg", "img_alt": "A dentist visit and dental tools in Vitalis clinic", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "TOOTH | BRUS | FLOSS | DEN-tist | KAV-ih-tee", "instructions": "Brush your teeth for exactly 2 minutes (time yourself!). Do you brush all surfaces? Write your dental routine in 4 steps.", "tip": "Nerissa says: Your teeth are your forever tools. Treat them like gold!"},
        "E": {"title": "Sophia: Banking Services", "time": 2, "img": "land6_banking-online-services.jpg", "img_alt": "Online banking and ATMs in Sophia financial district", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "ON-line | A-T-M | DE-bit | KRED-it | TRANS-fer", "instructions": "Write 3 banking words and their definitions. Ask an adult: do they use a bank? What do they use it for? Record their answers.", "tip": "Athena says: Understanding money systems gives you power over your financial future!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "What is one thing you want to save money for someday? Write the goal and how long you think it would take."}}},
        {"week": 4, "day": 3, "day_label": "Wednesday", "day_title": "Maps & Modes of Travel", "primary_land": 4, "primary_land_color": "#2563EB", "primary_char_img": "SELENE.jpg", "primary_char_names": "Selene & Ronan", "blocks": {"A": {"title": "Days, Months & Numbers", "time": 3, "img": "land1_days-months-numbers.jpg", "img_alt": "Calendar page and ordinal numbers in Harmonia", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "JAN-yoo-ere | FEB-roo-ere | MARCH | A-pril | MAY", "instructions": "Write all 12 months in order. How many start with J? With M? Cross out the month of your birthday. How many months until it?", "tip": "Amara says: Calendar fluency is time mastery. Own your year!"},
        "B": {"title": "Cooking Measurements", "time": 3, "img": "land2_cooking-measurements.jpg", "img_alt": "Measuring cups and spoons in a Numeria kitchen", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "CUP | TABLE-spoon | TEE-spoon | PINT | QUART | GAL-on", "instructions": "How many teaspoons in a tablespoon? (3!) How many tablespoons in 1/4 cup? (4!) Practice converting: 2 cups to tablespoons. Show work!", "tip": "Kwame says: Kitchen math is real-world math that tastes delicious!"},
        "C": {"title": "The Garden at Work", "time": 3, "img": "land3_the-garden.jpg", "img_alt": "A productive vegetable garden in Terrasol", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "GAR-den | SOY-ul | WEED | WAHR-ter | POL-ih-nayt | GROWS", "instructions": "Draw a garden with: 3 vegetables, bugs that help it (bees!), a water source, and soil layers. Label everything. Add sun and rain!", "tip": "Vesta says: A garden is the world's most patient science experiment!"},
        "D": {"title": "Vitalis Walking Challenge", "time": 2, "img": "land4_bicycle-walking.jpg", "img_alt": "Walking paths and cycling routes in Aquaria", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "WALK | BIKE | PATHS | EK-ser-syz | HEALTH | MYLE", "instructions": "Count your steps for 1 minute of normal walking. Multiply by 10 for your 10-minute total. Most adults walk 10,000 steps/day. How many minutes for you?", "tip": "Nerissa says: Walking is the most underrated exercise. It's powerful AND free!"},
        "E": {"title": "Aquaria: Seasons & Cycles", "time": 2, "img": "land4_seasons-nature-cycles.jpg", "img_alt": "The four seasons shown in Aquaria landscape", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "SPRI\u014a | SUM-er | FOL | WIN-ter | SY-kul | CHAYNJ", "instructions": "Draw a circle divided in 4 sections for the 4 seasons. Add: one plant and one animal for each season. Write the season names!", "tip": "Selene says: Seasons are Earth's way of breathing. Everything changes and returns!", "land": 4, "land_class": "land4", "land_name": "Aquaria", "icon": "\ud83c\udf0a", "subject": "Geography", "char_img": "RONAN.jpg", "char_names": "Ronan & Selene"},
        "F": {"reflection_prompt": "If Earth had 5 seasons, what would the new one be called? What would the weather be like? What would grow?"}}},
        {"week": 4, "day": 4, "day_label": "Thursday", "day_title": "School Subjects Showcase", "primary_land": 6, "primary_land_color": "#5ba4c9", "primary_char_img": "FELIX.jpg", "primary_char_names": "Felix & Athena", "blocks": {"A": {"title": "The Home Vocabulary", "time": 3, "img": "land1_the-home.jpg", "img_alt": "Rooms and furniture inside a Harmonia home", "img_source": "SOE Picture Dictionary \u2014 Land 1", "phonetic": "ROO-m | FUR-nih-cher | CEIL-ing | FLOOR | WIN-dow | DOOR", "instructions": "Write 8 home vocabulary words from the picture. Now write 3 sentences describing your home. Use at least 5 vocabulary words!", "tip": "Amara says: Home vocabulary helps you describe your world to new friends!"},
        "B": {"title": "Basic Math Operations", "time": 3, "img": "land2_basic-math-operations.jpg", "img_alt": "Addition, subtraction, multiplication and division in Numeria", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "ADD | SUB-trakt | MUL-tih-ply | dih-VIDE | E-KWALS", "instructions": "Solve one of each: 47+38=?, 93-26=?, 6\u00d79=?, 56\u00f77=?  Show your work. Circle the operation that feels hardest. Practice 3 more of those!", "tip": "Kwame says: Practice the hard ones FIRST. That's where the growth is!"},
        "C": {"title": "Ocean Beach Science", "time": 3, "img": "land3_the-ocean-beach.jpg", "img_alt": "Tide pools and beach life in Terrasol coast", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "TIDE | WAVE | SHELL | SAND | KRAB | STAR-fish", "instructions": "Draw a tide pool from memory or from the picture. Label 4 creatures. Write: How does a tide pool form? (Hint: tides go in and out!)", "tip": "Silas says: Tide pools are windows into the ocean world. So much life in one tiny space!"},
        "D": {"title": "Vitalis Produce Market", "time": 2, "img": "land5_the-produce-market.jpg", "img_alt": "Colorful fruit and vegetable stands in Vitalis market", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "PRO-dyoos | FRESH | OR-gan-ik | SEE-zon-ul | LOK-ul", "instructions": "Name 5 fruits or vegetables in the picture. Write: local (grown nearby) or not? In season (it's summer!) or not? Draw your top 3 picks!", "tip": "Octavia says: Fresh, local, seasonal food is the most nutritious. Shop smart!"},
        "E": {"title": "Sophia: School & Education", "time": 2, "img": "land6_school-subjects-education.jpg", "img_alt": "Classroom subjects displayed in Sophia academy", "img_source": "SOE Picture Dictionary \u2014 Land 6", "phonetic": "MATH | SY-ens | HISS-tree | ENG-lish | ART | MU-zik", "instructions": "List 6 school subjects. Write your favorite and why. Write one that's hard for you. Write ONE strategy you'll try to improve!", "tip": "Athena says: Hard subjects are just skills you haven't mastered yet. Yet is the most powerful word!", "land": 6, "land_class": "land6", "land_name": "Sophia", "icon": "\u2696\ufe0f", "subject": "Civics", "char_img": "ATHENA.jpg", "char_names": "Athena & Felix"},
        "F": {"reflection_prompt": "If you were a teacher for one day, what subject would you teach? How would you make it fun? Plan your lesson in 3 steps."}}},
        {"week": 4, "day": 5, "day_label": "Friday", "day_title": "Week 4 World Wonder Complete!", "primary_land": 7, "primary_land_color": "#9678c4", "primary_char_img": "ELIAS.jpg", "primary_char_names": "Elias & Ezra", "blocks": {"A": {"title": "Emergency & Postal Services", "time": 3, "img": "land4_emergency-services.jpg", "img_alt": "Emergency vehicles and services in Aquaria city", "img_source": "SOE Picture Dictionary \u2014 Land 4", "phonetic": "AM-byoo-lans | FYRE-TRUk | PO-leece | RES-kyoo | HELP", "instructions": "Write 5 emergency service words. Write the correct number to call in an emergency (911 in USA). When should you call for help?", "tip": "Ronan says: Knowing when and how to call for help is a life skill. Practice it!"},
        "B": {"title": "Problem Solving: Word Problems", "time": 3, "img": "land2_problem-solving-logic.jpg", "img_alt": "Students solving word problems in Numeria lab", "img_source": "SOE Picture Dictionary \u2014 Land 2", "phonetic": "PROB-lem | UND-er-stand | PLAN | SOLVE | CHECK", "instructions": "Make up your own word problem using numbers from your life (your age, family size, etc.). Write it and solve it. Share with a family member!", "tip": "Kwame says: When you write math problems, you understand math deeply!"},
        "C": {"title": "Shapes in the World", "time": 3, "img": "land3_shapes-in-the-world.jpg", "img_alt": "Geometric shapes found in nature and buildings", "img_source": "SOE Picture Dictionary \u2014 Land 3", "phonetic": "SHAPE | NA-cher | HEXA-gon | SPI-ral | SIM-et-ree", "instructions": "Look around you. Find 5 real-world shapes: Write the object and the shape. Draw each object. Which shape appears most in nature?", "tip": "Vesta says: Beehives are hexagons because it's the strongest and most efficient shape. Nature is a mathematician!"},
        "D": {"title": "Vitalis Sleep Science", "time": 2, "img": "land5_sleep-rest.jpg", "img_alt": "Sleep cycle diagram and rest tips in Vitalis", "img_source": "SOE Picture Dictionary \u2014 Land 5", "phonetic": "SLEEP | DREEM | REM | SAIKL | REST | MEM-oh-ree", "instructions": "Design your perfect bedtime routine in 5 steps. Include: a wind-down activity, no screens, a write/draw journal time, and lights out time!", "tip": "Nerissa says: A consistent bedtime routine is one of the best gifts you can give your brain!"},
        "E": {"title": "Celestia Week 4 Review", "time": 2, "img": "land7_planet-earth.jpg", "img_alt": "Planet Earth from space shown in Celestia observatory", "img_source": "SOE Picture Dictionary \u2014 Land 7", "phonetic": "PLAN-et | ORE-bit | AK-sis | RO-tate | RE-volv | GRAV-ih-tee", "instructions": "Draw Earth. Label: North Pole, South Pole, equator, and one continent. Write one amazing fact about Earth you learned this week!", "tip": "Ezra says: Earth is the only planet we know that has life. It's the most precious thing in the universe!", "land": 7, "land_class": "land7", "land_name": "Celestia", "icon": "\u2728", "subject": "Review & Reflection", "char_img": "ELIAS.jpg", "char_names": "Elias & Ezra"},
        "F": {"reflection_prompt": "4 weeks! Halfway! Color your Quest Map halfway point. Write: The world-wonder I learned that amazed me most was ___ because ___"}}
        }
      ]
